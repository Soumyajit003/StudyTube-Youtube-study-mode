{
    "manifest_version": 3,
    "name": "StudyTube - Stay Focused on Youtube",
    "version": "1.0",
    "description": "A Chrome extension that helps you stay focused while studying on Youtube.",
    "permissions": [
        "tabs",
        "storage",
        "activeTab",
        "scripting"
    ],
    "background":{
        "service_worker": "background.js"
    },
    "action":{
        "default_popup": "index.html"
    },
    "content_scripts": [
        {
            "matches": ["*://www.youtube.com/*"],
            "js": ["content.js"]
        }
    ]
}